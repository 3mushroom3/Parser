# Server Settings
PORT=3001
NODE_ENV=development
JWT_SECRET=replace-with-a-random-string-at-least-32-chars-long

# Database
DB_PATH=./data/fsa_parser.db

# FSA Parser Config
FSA_BASE_URL=https://pub.fsa.gov.ru
FSA_CRON_SCHEDULE=*/30 * * * *
FSA_PAGE_SIZE=100
FSA_FETCH_CONCURRENCY=3
FSA_DELAY_MS=1500

# FNS / Dadata API
# Get your token at https://dadata.ru/
DADATA_TOKEN=

# Logging
LOG_LEVEL=info

# ЮКасса (получить в личном кабинете: https://yookassa.ru/my/shop-settings/integration)
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=

# URL сайта (для редиректа после оплаты и вебхуков)
APP_URL=https://your-domain.ru

# Цены тарифных планов (в рублях)
PLAN_1M_PRICE=990
PLAN_3M_PRICE=2490
PLAN_12M_PRICE=7990
